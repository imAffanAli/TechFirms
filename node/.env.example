# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────
# Local Postgres. In production use the Supabase pooled URL for DATABASE_URL
# (append ?pgbouncer=true) and the direct connection for DIRECT_URL (migrations).
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/techfirms
DIRECT_URL=postgresql://postgres:PASSWORD@localhost:5432/techfirms

# ── AI (Anthropic Claude) ────────────────────────────────
# https://console.anthropic.com — used for descriptions, sentiment, matching, CIS justification, moderation.
ANTHROPIC_API_KEY=

# ── Later (leave blank for now) ──────────────────────────
# STRIPE_SECRET_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
